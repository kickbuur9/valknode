[req]
distinguished_name = req_distinguished_name
req_extensions = v3_req
prompt = no

[req_distinguished_name]
C = US
ST = CA
L = San Francisco
O = MyCompany
OU = FleetServer
CN = fleet-server # Common Name should match your Kubernetes service name

[v3_req]
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = fleet-server # Kubernetes Service Name
DNS.2 = fleet-server.default.svc.cluster.local # FQDN within Kubernetes (adjust 'default' if using a different namespace)
IP.1 = 127.0.0.1 # For local testing/access
